# Copy to .env and edit. Only ARNOS_DOMAIN is strictly required.

# The public domain clients dial. On Coolify this is the domain you attach to
# the service; Coolify's Traefik answers on 443 for it and provides SSL.
ARNOS_DOMAIN=vpn.example.com

# TLS mode:
#   proxy (default) — Coolify/Traefik terminates TLS; ArnosVPN speaks plain WS
#                     on an internal port. Use this when 443 is taken (expose).
#   self            — ArnosVPN terminates TLS itself (standalone / random port).
ARNOS_TLS_MODE=proxy

# Public port clients dial (goes into the connect URI). 443 for Coolify.
ARNOS_PUBLIC_PORT=443

# Optional: pin the pre-shared key (base64, 32 bytes). Leave empty to have the
# server generate and persist one in the data volume. Generate one with:
#   docker compose run --rm arnosvpn arnosvpnctl genpsk
ARNOS_PSK=

# ---- only for ARNOS_TLS_MODE=self ----
# Certificate source: traefik (reuse acme.json) | letsencrypt (obtain our own)
CERT_PROVIDER=traefik
# Host path to Traefik's acme.json (Coolify's bundled proxy stores it here):
TRAEFIK_ACME_PATH=/data/coolify/proxy/acme.json
# For CERT_PROVIDER=letsencrypt: contact email for the ACME account.
ARNOS_ACME_EMAIL=admin@example.com
