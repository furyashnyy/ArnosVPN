# Copy to .env and edit. Only ARNO_DOMAIN is strictly required.

# Domain clients connect to; must match the TLS certificate.
ARNO_DOMAIN=vpn.example.com

# Certificate source: traefik (default) | letsencrypt
CERT_PROVIDER=traefik

# For CERT_PROVIDER=traefik: host path to Traefik's acme.json.
# Coolify's bundled proxy usually stores it here:
TRAEFIK_ACME_PATH=/data/coolify/proxy/acme.json

# For CERT_PROVIDER=letsencrypt: contact email for the ACME account.
ARNO_ACME_EMAIL=admin@example.com

# Optional: pin the pre-shared key (base64, 32 bytes). Leave empty to have the
# server generate and persist one in the data volume. Generate with:
#   docker run --rm arnovpn:latest -- arnovpnctl genpsk
ARNO_PSK=
